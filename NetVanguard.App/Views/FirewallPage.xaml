<Page
    x:Class="NetVanguard.App.Views.FirewallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NetVanguard.App.Views"
    xmlns:converters="using:NetVanguard.App.Converters"
    xmlns:models="using:NetVanguard.Core.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:ActionToIconConverter x:Key="ActionToIconConverter"/>
        <converters:ActionToColorConverter x:Key="ActionToColorConverter"/>
    </Page.Resources>

    <Grid x:Name="LayoutRoot" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,20">
            <TextBlock Text="Windows Firewall Rules" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{x:Bind ViewModel.LoadRulesCommand}" VerticalAlignment="Center"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" VerticalAlignment="Center" Margin="10,0,0,0" Width="20" Height="20"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Rules, Mode=OneWay}" SelectionMode="None" 
                  Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="10">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FirewallRuleModel">
                    <Grid Padding="12,8" Margin="0,4" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Action/Direction Icon -->
                        <FontIcon Grid.Column="0" FontFamily="Segoe Fluent Icons" 
                                  Glyph="{x:Bind Action, Mode=OneWay, Converter={StaticResource ActionToIconConverter}}" 
                                  Foreground="{x:Bind Action, Mode=OneWay, Converter={StaticResource ActionToColorConverter}}"
                                  VerticalAlignment="Center" Margin="0,0,16,0" FontSize="20"/>

                        <!-- Rule Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Description}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- App Path -->
                        <TextBlock Grid.Column="2" Text="{x:Bind ApplicationName}" FontSize="12" Foreground="DarkGray" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="10,0"/>

                        <!-- Direction -->
                        <TextBlock Grid.Column="3" Text="{x:Bind Direction, Mode=OneWay}" VerticalAlignment="Center" FontSize="13"/>

                        <!-- Enable/Disable CheckBox -->
                        <CheckBox Grid.Column="4" IsChecked="{x:Bind Enabled, Mode=OneWay}" Content="Enabled" Command="{Binding ElementName=LayoutRoot, Path=DataContext.ToggleRuleCommand}" CommandParameter="{Binding}" Margin="10,0" VerticalAlignment="Center"/>

                        <!-- Delete Button -->
                        <Button Grid.Column="5" Content="Delete" Command="{Binding ElementName=LayoutRoot, Path=DataContext.DeleteRuleCommand}" CommandParameter="{Binding}" Background="Transparent" Foreground="Red" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
