<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="NetVanguard.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NetVanguard.App"
    xmlns:models="using:NetVanguard.Core.Models"
    xmlns:converters="using:NetVanguard.App.Converters"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:helpers="using:NetVanguard.App.Helpers"
    mc:Ignorable="d" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToAccentConverter x:Key="BoolToAccentConverter"/>
    </Page.Resources>
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Traffic Dashboard" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <!-- Real-time Traffic Graph -->
        <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Total System Traffic (MB/s)" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                <lvc:CartesianChart Grid.Row="1"
                    Series="{Binding TrafficSeries, Mode=OneWay}"
                    XAxes="{Binding XAxes, Mode=OneWay}"
                    YAxes="{Binding YAxes, Mode=OneWay}"
                    TooltipPosition="Hidden">
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <!-- Showcase Area -->
        <Border Grid.Row="2" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="16">
            <Grid>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12">
                        <TextBlock Text="Network Showcase" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                        
                        <!-- View Switcher -->
                        <StackPanel Orientation="Horizontal" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" Padding="4" CornerRadius="4">
                            <Button helpers:CursorExtensions.Cursor="Hand" Content="Process" Command="{x:Bind ViewModel.SwitchViewCommand}" CommandParameter="Process" 
                                    Background="{x:Bind ViewModel.IsProcessView, Mode=OneWay, Converter={StaticResource BoolToAccentConverter}}" Padding="12,4"/>
                            <Button helpers:CursorExtensions.Cursor="Hand" Content="Detailed" Command="{x:Bind ViewModel.SwitchViewCommand}" CommandParameter="Detailed" 
                                    Background="{x:Bind ViewModel.IsDetailedView, Mode=OneWay, Converter={StaticResource BoolToAccentConverter}}" Padding="12,4"/>
                            <Button helpers:CursorExtensions.Cursor="Hand" Content="Adapter" Command="{x:Bind ViewModel.SwitchViewCommand}" CommandParameter="Adapter" 
                                    Background="{x:Bind ViewModel.IsAdapterView, Mode=OneWay, Converter={StaticResource BoolToAccentConverter}}" Padding="12,4"/>
                            <Button helpers:CursorExtensions.Cursor="Hand" Content="Domain" Command="{x:Bind ViewModel.SwitchViewCommand}" CommandParameter="Domain" 
                                    Background="{x:Bind ViewModel.IsDomainView, Mode=OneWay, Converter={StaticResource BoolToAccentConverter}}" Padding="12,4"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                <!-- Column Headers (Process/Detailed) -->
                <Grid Grid.Row="2" Padding="4" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" CornerRadius="4" 
                      Visibility="{x:Bind ViewModel.IsAppListView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushName, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Name">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Process" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowName, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushDownload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Download">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Download" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowDownload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushUpload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Upload">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Upload" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowUpload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="3" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushActivity, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Activity" Width="100">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Activity" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowActivity, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Column Headers (Adapter) -->
                <Grid Grid.Row="2" Padding="4" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" CornerRadius="4" 
                      Visibility="{x:Bind ViewModel.IsAdapterView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushName, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Name">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Adapter" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowName, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushDownload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Download">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Download" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowDownload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushUpload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Upload">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Upload" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowUpload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Column Headers (Domain) -->
                <Grid Grid.Row="2" Padding="4" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" CornerRadius="4" 
                      Visibility="{x:Bind ViewModel.IsDomainView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushDomain, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Domain">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Domain / IP" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowDomain, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushDownload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Download">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Download" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowDownload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                    <Button helpers:CursorExtensions.Cursor="Hand" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="{x:Bind ViewModel.SortBrushUpload, Mode=OneWay}" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Upload">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Upload" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind ViewModel.SortArrowUpload, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Process/Detailed List with Row offset -->
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ActiveApplications, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedApplication, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.IsAppListView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NetworkApplication">
                            <Grid Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind ProcessName, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind ExecutablePath, Mode=OneWay}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayBytesReceived, Mode=OneWay}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind DisplayBytesSent, Mode=OneWay}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind LastSeen, Mode=OneWay}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Width="100"/>
                                <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Padding="8" ToolTipService.ToolTip="Set Limit" Click="SetLimit_Click" VerticalAlignment="Center">
                                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" FontSize="14" Foreground="Gray"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Adapter List with Row offset -->
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.AdapterTraffic, Mode=OneWay}" SelectionMode="None"
                          Visibility="{x:Bind ViewModel.IsAdapterView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AdapterTraffic">
                            <Grid Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayBytesReceived, Mode=OneWay}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind DisplayBytesSent, Mode=OneWay}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Domain List with Row offset -->
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DomainTraffic, Mode=OneWay}" 
                          SelectedItem="{x:Bind ViewModel.SelectedDomain, Mode=TwoWay}"
                          Visibility="{x:Bind ViewModel.IsDomainView, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DomainTraffic">
                            <Grid Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind DomainName, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind RemoteIp, Mode=OneWay}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayBytesReceived, Mode=OneWay}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind DisplayBytesSent, Mode=OneWay}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                    </Grid>

                    <Border Grid.Column="1" Width="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="8,0" 
                            Visibility="{x:Bind ViewModel.IsDetailPaneVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Relational Detail Pane -->
                    <Border Grid.Column="2" Padding="12" Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" CornerRadius="8" Width="300"
                            Visibility="{x:Bind ViewModel.IsDetailPaneVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <!-- App Detail -->
                            <StackPanel Visibility="{x:Bind ViewModel.IsAppDetailVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="16">
                                <TextBlock Text="Process Analytics" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Gray"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.AppDetailName, Mode=OneWay}" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind ViewModel.AppDetailPath, Mode=OneWay}" FontSize="11" Foreground="Gray" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="4" Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Engaging Domains" FontWeight="SemiBold" FontSize="12"/>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.AppDetailDomains, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="12" Margin="0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Domain Detail -->
                            <StackPanel Visibility="{x:Bind ViewModel.IsDomainDetailVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="16">
                                <TextBlock Text="Domain Relational Map" Style="{StaticResource SubtitleTextBlockStyle}" Foreground="Gray"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ViewModel.DomainDetailName, Mode=OneWay}" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind ViewModel.DomainDetailIp, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>

                                <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="4" Padding="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Associated Apps" FontWeight="SemiBold" FontSize="12"/>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.DomainDetailApps, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="12" Margin="0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
