<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="NetVanguard.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:NetVanguard.App"
    xmlns:models="using:NetVanguard.Core.Models"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Traffic Dashboard" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,24" />

        <!-- Real-time Traffic Graph -->
        <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="System Traffic (Last 30s)" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                <lvc:CartesianChart Grid.Row="1"
                    Series="{x:Bind ViewModel.TrafficSeries, Mode=OneWay}"
                    XAxes="{x:Bind ViewModel.XAxes, Mode=OneWay}"
                    YAxes="{x:Bind ViewModel.YAxes, Mode=OneWay}"
                    TooltipPosition="Hidden">
                </lvc:CartesianChart>
            </Grid>
        </Border>

        <!-- Top Applications List -->
        <Border Grid.Row="2" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Active Applications" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12"/>
                
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ActiveApplications, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:NetworkApplication">
                            <Grid Padding="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{x:Bind ProcessName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind ExecutablePath}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE896;" FontSize="12" Foreground="LightBlue"/>
                                    <TextBlock Text="{x:Bind BytesReceived}" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE898;" FontSize="12" Foreground="MediumPurple"/>
                                    <TextBlock Text="{x:Bind BytesSent}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
