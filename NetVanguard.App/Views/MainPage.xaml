<Page
    x:Class="NetVanguard.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:NetVanguard.App.Helpers"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Background="Transparent" Grid.Row="0">
            <!-- Title Bar content -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8F1;" FontSize="14" Margin="0,0,12,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="Net-Vanguard" FontSize="12" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <NavigationView x:Name="NavView" Grid.Row="1" PaneDisplayMode="Left" IsPaneOpen="False" IsSettingsVisible="True" SelectionChanged="NavView_SelectionChanged" Loaded="NavView_Loaded" OpenPaneLength="180">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Limits" Content="Network Limits">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE81D;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Firewall" Content="Firewall Rules">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE773;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>
    </Grid>
</Page>
