## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Lo]g/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if using tasks.json or launch.json
#.vscode/

# Output of dotnet publish
[Pp]ublish/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# xUnit
TestCheck.xml

# JetBrains Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# Other Tools
*.Cache
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.user
*.resharper.user
*.psess
*.vsp
*.vspx
*.sap
*.orig

# NuGet Packages
*.nupkg
# The packages folder is ignored by default
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# project-specific NuGet files
project.lock.json
project.assets.json
*.nuget.cache


# StyleCop
StyleCopReport.xml

# Files for Windows Visual Studio LightSwitch
**/*.HTMLClient/GeneratedArtifacts
**/*.DesktopClient/GeneratedArtifacts
**/*.DesktopClient/ModelManifest.xml
**/*.Server/GeneratedArtifacts
**/*.Server/ModelManifest.xml
_PagingCookie_*

# Others
sql/
*.Cache
ClientBin/
[Ss][Ee][Rr][Vv][Ee][Rr].[Gg].cs
[Gg]enerated/
**/*.log

# WinUI 3 / Windows App SDK
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxrecipe
*.msix
*.msixbundle
*.msixrecipe

# .NET
project.lock.json
project.assets.json
.dotnet/
# Backup files
*.bak
*.tmp

# MacOS
.DS_Store
NetVanguard.App/obj/project.nuget.cache
NetVanguard.Core/obj/project.nuget.cache
NetVanguard.Daemon/obj/project.nuget.cache
